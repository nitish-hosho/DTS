# ── Model ─────────────────────────────────────────────────────────────────────
# HuggingFace model id or local path (must be a CausalLM supported by transformers)
MODEL_NAME_OR_PATH=meta-llama/Llama-3.1-8B-Instruct

# Device: auto | cuda | cpu
# "auto" picks CUDA if available, otherwise CPU.
MODEL_DEVICE=auto

# ── DTS Hyperparameters ───────────────────────────────────────────────────────
# These set the server defaults; callers can override per-request.
DTS_SETTLING_THRESHOLD=0.5
DTS_DEPTH_FRACTION=0.85

# ── HuggingFace access (needed for gated models like LLaMA) ──────────────────
HUGGING_FACE_HUB_TOKEN=hf_...
